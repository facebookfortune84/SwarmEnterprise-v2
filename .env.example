# SwarmOS environment schema — copy to .env and fill (NEVER commit .env)

# --- Domains & deploy profile ---
PRIMARY_DOMAIN=realms2riches.com
CORP_DOMAIN=corp.realms2riches.com
API_DOMAIN=api.realms2riches.com
TECH_DOMAIN=realms2riches.tech
DEPLOY_PROFILE=local-laptop-ollama
ACME_EMAIL=ops@realms2riches.com
BACKEND_IMAGE=ghcr.io/your-org/swarmenterprise-backend:latest

# --- Ollama (laptop host reachable from WSL/Docker) ---
# Docker Desktop: http://host.docker.internal:11434
# WSL on Hyper-V VM: http://<LAPTOP_LAN_IP>:11434  (ipconfig on Windows laptop)
OLLAMA_URL=http://host.docker.internal:11434
LAPTOP_OLLAMA_HOST=
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_K=10
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=4096
EMBEDDING_MODEL=nomic-embed-text:latest

# --- LLM providers ---
ELEVENLABS_API_KEY=
GROQ_API_KEY=
GROQ_BASE_URL=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
HUBSPOT_API_KEY=
HUBSPOT_ACCESS_TOKEN=

# --- Telemetry ---
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
OTEL_OTLP_ENDPOINT=
SENTRY_DSN=

# --- Infra / IONOS / Cloudflare ---
IONOS_API_PUBLIC_PREFIX=
IONOS_API_SECRET=
CLOUDFLARE_TUNNEL_TOKEN=
COTURN_SHARED_SECRET=

# --- Data stores ---
LINEAR_API_KEY=
CHROMA_SERVER_HOST=chromadb
CHROMA_SERVER_HTTP_PORT=8000
DATABASE_URL=
POSTGRES_HOST=postgres
POSTGRES_DB=swarm
POSTGRES_USER=swarm
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0

# --- Email ---
CONTACT_EMAIL=
SMTP_USER=
SMTP_PASS=
SMTP_SERVER=
SMTP_PORT=587
IMAP_USER=
IMAP_PASS=
IMAP_SERVER=

# --- Stripe ---
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=
STRIPE_TEST_MODE=TRUE

# --- App URLs ---
FRONTEND_URL=https://realms2riches.com
BACKEND_URL=https://api.realms2riches.com
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
MARKETING_SITE_URL=https://realms2riches.com
VITE_API_URL=https://api.realms2riches.com
VITE_BACKEND_URL=https://api.realms2riches.com
COOKIE_DOMAIN=.realms2riches.com
CORS_ORIGINS=https://realms2riches.com,https://corp.realms2riches.com

# --- Brand ---
BRAND_NAME=Realms2Riches
PRODUCT_NAME=SwarmOS

# --- Social / ads ---
FACEBOOK_APP_ID=
FACEBOOK_BUSINESS_ID=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=
FACEBOOK_USER_ID=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_PROFILE_URN=
LINKEDIN_REFRESH_TOKEN=

# --- GitHub / registry / deploy SSH ---
GITHUB_REPO=
GITHUB_TOKEN=
GHCR_USERNAME=
GHCR_PASSWORD=
DOCKER_REGISTRY_HOST=ghcr.io
DOCKER_REGISTRY_USER=
DOCKER_REGISTRY_PASS=
DOCKER_REGISTRY_PASSWORD=
SSH_DEPLOY_HOST=
SSH_DEPLOY_USER=
SSH_DEPLOY_PRIVATE_KEY=
SOCIAL_GITHUB_URL=
SOCIAL_LINKEDIN_URL=
SOCIAL_TWITTER_HANDLE=
SOCIAL_YOUTUBE_URL=

# --- Runtime ---
PYTHONPATH=.
LOG_LEVEL=INFO
ENV=development
ENV_MODE=local
SWARM_OUTPUT_DIR=
SWARM_REPO_ROOT=
SWARM_DB_URL=
SWARM_PG_DIR=
ANALYTICS_ENABLED=false
OUTREACH_ENABLED=true
OUTREACH_DRY_RUN=true
OUTREACH_TEST_RECIPIENT=
DRY_RUN_MODE=true
TEST_MODE=true
CIRCUIT_BREAKER_THRESHOLD=5
RECOVERY_TIMEOUT=60
TASK_QUEUE_MAX_SIZE=1000
GIT_DISCOVERY_ACROSS_FILESYSTEM=0
OPS_HEAL_INTERVAL_SEC=300
TENANT_BOX_IMAGE=redis:7-alpine
TENANT_BOX_NETWORK=swarmnet
