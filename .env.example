# SwarmOS environment schema — copy to .env and fill (NEVER commit .env)
# RWV Techsolutions LLC · 1091 Harrison Ave Elkins, WV 26241
# Run `python scripts/generate_secrets.py` to generate secure random values.
# Run `python scripts/validate_env.py`       to check all required variables.

# --- Domains & deploy profile ---
PRIMARY_DOMAIN=realms2riches.com
CORP_DOMAIN=corp.realms2riches.com
API_DOMAIN=api.realms2riches.com
TECH_DOMAIN=realms2riches.tech
DEPLOY_PROFILE=local-laptop-ollama  # local-laptop-ollama | staging | production-realms2riches
ACME_EMAIL=ops@realms2riches.com    # Let's Encrypt registration email for TLS certificates
BACKEND_IMAGE=ghcr.io/your-org/swarmenterprise-backend:latest  # Docker image for the backend service

# --- Ollama (laptop host reachable from WSL/Docker) ---
# Docker Desktop: http://host.docker.internal:11434
# WSL on Hyper-V VM: http://<LAPTOP_LAN_IP>:11434  (ipconfig on Windows laptop)
OLLAMA_URL=http://host.docker.internal:11434
LAPTOP_OLLAMA_HOST=     # LAN IP of the Windows laptop running Ollama (e.g. 192.168.1.50)
OLLAMA_API_KEY=         # Optional bearer token if Ollama is behind an auth proxy
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_K=10
OLLAMA_TOP_P=0.9
OLLAMA_NUM_CTX=4096
EMBEDDING_MODEL=nomic-embed-text:latest

# --- LLM providers ---
ELEVENLABS_API_KEY=     # ElevenLabs text-to-speech API key — get from https://elevenlabs.io/app/api-key
GROQ_API_KEY=           # Groq inference API key — get from https://console.groq.com/keys
GROQ_BASE_URL=          # Groq base URL override (leave blank to use default)
GOOGLE_API_KEY=         # Google Generative AI API key — get from https://aistudio.google.com/apikey
ANTHROPIC_API_KEY=      # Anthropic Claude API key — get from https://console.anthropic.com/settings/keys
HUBSPOT_API_KEY=        # HubSpot API key (legacy) — prefer HUBSPOT_ACCESS_TOKEN
HUBSPOT_ACCESS_TOKEN=   # HubSpot private app access token — get from HubSpot → Settings → Integrations

# --- Telemetry ---
CREWAI_DISABLE_TELEMETRY=true
OTEL_SDK_DISABLED=true
OTEL_OTLP_ENDPOINT=     # OpenTelemetry collector endpoint (e.g. http://otel-collector:4318)
SENTRY_DSN=             # Sentry error-tracking DSN — get from https://sentry.io → Project Settings → Client Keys

# --- Infra / IONOS / Cloudflare ---
IONOS_API_PUBLIC_PREFIX=  # IONOS public IP prefix for API access control
IONOS_API_SECRET=         # IONOS API secret key — get from IONOS Developer portal
CLOUDFLARE_TUNNEL_TOKEN=  # Cloudflare Tunnel connector token — get from Zero Trust → Tunnels
COTURN_SHARED_SECRET=     # Shared secret for COTURN TURN server (generate with `openssl rand -hex 32`)

# --- Data stores ---
LINEAR_API_KEY=           # Linear project-management API key — get from https://linear.app/settings/api
CHROMA_SERVER_HOST=chromadb
CHROMA_SERVER_HTTP_PORT=8000
DATABASE_URL=             # Full Postgres DSN: postgresql+asyncpg://user:password@host:5432/dbname
POSTGRES_HOST=postgres
POSTGRES_DB=swarm
POSTGRES_USER=swarm
POSTGRES_PASSWORD=        # Strong random password — generate with `python scripts/generate_secrets.py`
POSTGRES_PORT=5432
REDIS_URL=redis://redis:6379/0  # Redis connection URL; add :password@ for authenticated Redis

# --- Auth & security (CRITICAL — generate with scripts/generate_secrets.py) ---
JWT_SECRET_KEY=           # 64-char hex — HMAC key for signing JWT access/refresh tokens
SECRET_KEY=               # 64-char hex — signing key for sessions, cookies, and CSRF tokens
ENCRYPTION_KEY=           # 32-byte URL-safe base64 — symmetric key for encrypting stored PII

# --- Email ---
CONTACT_EMAIL=            # Public contact address shown in outbound emails (e.g. ops@realms2riches.com)
SMTP_USER=                # SMTP login username / email address (e.g. ops@realms2riches.com)
SMTP_PASS=                # SMTP password or app-specific password (see docs/guides/SECRETS_MANAGEMENT.md)
SMTP_SERVER=              # SMTP hostname (e.g. smtp.gmail.com, smtp.sendgrid.net, email-smtp.us-east-1.amazonaws.com)
SMTP_PORT=587             # 587 = STARTTLS (recommended) · 465 = SSL · 25 = plain
IMAP_USER=                # IMAP login username for reading inbound email
IMAP_PASS=                # IMAP password or app-specific password
IMAP_SERVER=              # IMAP hostname (e.g. imap.gmail.com)

# --- Stripe ---
STRIPE_API_KEY=           # Secret key: sk_test_… (test) or sk_live_… (prod) — get from Stripe Dashboard → Developers → API keys
STRIPE_WEBHOOK_SECRET=    # Webhook signing secret: whsec_… — get from Stripe Dashboard → Developers → Webhooks
STRIPE_PUBLISHABLE_KEY=   # Publishable key: pk_test_… or pk_live_… — get from Stripe Dashboard → Developers → API keys
STRIPE_TEST_MODE=TRUE     # Set to FALSE when switching to live Stripe keys

# --- App URLs ---
FRONTEND_URL=https://realms2riches.com
BACKEND_URL=https://api.realms2riches.com
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
MARKETING_SITE_URL=https://realms2riches.com
VITE_API_URL=https://api.realms2riches.com
VITE_BACKEND_URL=https://api.realms2riches.com
COOKIE_DOMAIN=.realms2riches.com
CORS_ORIGINS=https://realms2riches.com,https://corp.realms2riches.com

# --- Brand ---
BRAND_NAME=Realms2Riches
PRODUCT_NAME=SwarmOS

# --- Social / ads ---
FACEBOOK_APP_ID=           # Facebook App ID — get from https://developers.facebook.com/apps
FACEBOOK_BUSINESS_ID=      # Facebook Business Manager ID
FACEBOOK_CLIENT_ID=        # Facebook OAuth client ID
FACEBOOK_CLIENT_SECRET=    # Facebook OAuth client secret
FACEBOOK_PAGE_ID=          # Facebook Page numeric ID
FACEBOOK_PAGE_TOKEN=       # Facebook Page access token with publish_pages permission
FACEBOOK_USER_ID=          # Facebook user numeric ID
LINKEDIN_ACCESS_TOKEN=     # LinkedIn OAuth2 access token with w_member_social permission
LINKEDIN_CLIENT_ID=        # LinkedIn app client ID — get from https://www.linkedin.com/developers/apps
LINKEDIN_CLIENT_SECRET=    # LinkedIn app client secret
LINKEDIN_PROFILE_URN=      # LinkedIn profile URN (e.g. urn:li:person:XXXXXXX)
LINKEDIN_REFRESH_TOKEN=    # LinkedIn OAuth2 refresh token for token renewal

# --- GitHub / registry / deploy SSH ---
GITHUB_REPO=               # GitHub repository in owner/repo format (e.g. rwv-techsolutions/swarmenterprise)
GITHUB_TOKEN=              # GitHub Personal Access Token or fine-grained token with repo scope
GHCR_USERNAME=             # GitHub Container Registry username (same as GitHub username)
GHCR_PASSWORD=             # GitHub Container Registry password — use a PAT with read:packages scope
DOCKER_REGISTRY_HOST=ghcr.io
DOCKER_REGISTRY_USER=      # Docker registry login username
DOCKER_REGISTRY_PASS=      # Docker registry login password / token
DOCKER_REGISTRY_PASSWORD=  # Alias for DOCKER_REGISTRY_PASS (some tooling uses this key)
SSH_DEPLOY_HOST=           # SSH hostname of the production deploy target (e.g. 1.2.3.4)
SSH_DEPLOY_USER=           # SSH username on the deploy target (e.g. deploy)
SSH_DEPLOY_PRIVATE_KEY=    # Base64-encoded PEM private key for SSH deploy (use GitHub secret in CI)
SOCIAL_GITHUB_URL=         # Public GitHub org/profile URL for social links
SOCIAL_LINKEDIN_URL=       # Public LinkedIn company page URL for social links
SOCIAL_TWITTER_HANDLE=     # Twitter/X handle without @ (e.g. realms2riches)
SOCIAL_YOUTUBE_URL=        # YouTube channel URL for social links

# --- Runtime ---
PYTHONPATH=.
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
ENV=development            # development | staging | production
ENV_MODE=local             # local | cloud
SWARM_OUTPUT_DIR=          # Absolute path for swarm agent output files (defaults to ./outputs)
SWARM_REPO_ROOT=           # Absolute path to the repository root (auto-detected if blank)
SWARM_DB_URL=              # Override DATABASE_URL for swarm-specific DB connection (leave blank to use DATABASE_URL)
SWARM_PG_DIR=              # Path to Postgres data directory when running Postgres locally
ANALYTICS_ENABLED=false
OUTREACH_ENABLED=true
OUTREACH_DRY_RUN=true
OUTREACH_TEST_RECIPIENT=   # Email address to receive all outreach in dry-run mode (e.g. robertdemottojr50@gmail.com)
DRY_RUN_MODE=true          # true = no external side-effects; false = live sends/charges
TEST_MODE=true             # true = use test credentials and test data
CIRCUIT_BREAKER_THRESHOLD=5
RECOVERY_TIMEOUT=60
TASK_QUEUE_MAX_SIZE=1000
GIT_DISCOVERY_ACROSS_FILESYSTEM=0
OPS_HEAL_INTERVAL_SEC=300
TENANT_BOX_IMAGE=redis:7-alpine
TENANT_BOX_NETWORK=swarmnet
