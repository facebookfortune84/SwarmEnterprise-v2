# Example .env for SwarmEnterprise_v2
# Copy to .env and fill values before running in production

# LLM / Ollama
OLLAMA_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.1
EMBEDDING_MODEL=nomic-embed-text:latest

# API Keys
ELEVENLABS_API_KEY=
GROQ_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# Database (production Postgres recommended)
DATABASE_URL=postgresql+psycopg://user:pass@hostname:5432/swarm_enterprise_v2
POSTGRES_HOST=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
REDIS_URL=

# Email/SMTP
CONTACT_EMAIL=
SMTP_USER=
SMTP_PASS=
SMTP_SERVER=
SMTP_PORT=587

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TEST_MODE=TRUE

# App URLs
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Feature flags
LOG_LEVEL=INFO
ANALYTICS_ENABLED=FALSE
OUTREACH_ENABLED=FALSE
DRY_RUN_MODE=TRUE
TEST_MODE=TRUE
ENV=DEV
