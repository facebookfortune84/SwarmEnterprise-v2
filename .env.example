# Production environment variables - DO NOT COMMIT SECRETS
# Copy to .env locally and populate with real values; keep .env out of VCS.

# Ollama LLM gateway
OLLAMA_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TEMPERATURE=0.1

# Chroma / Vector DB
CHROMA_SERVER_HOST=chromadb
CHROMA_SERVER_HTTP_PORT=8000
EMBEDDING_MODEL=nomic-embed-text:latest

# SMTP (outreach)
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_TEST_MODE=TRUE

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SWARM_OUTPUT_DIR=/mnt/c/SwarmEnterprise_v2/output
LOG_LEVEL=INFO

# Telemetry/OTEL (enable in prod)
OTEL_SDK_DISABLED=FALSE

# Security: rotate any keys found in repo immediately and store secrets in a secrets manager.
